  "keyFeatures": [
    "Custom Tailwind CSS utilities with lum-bg, lum-btn, lum-card, and lum-input classes",
    "Advanced color mixing with OKLCH color space support",
    "Depth effects with configurable shadows and borders",
    "Superellipse border radius for modern UI aesthetics",
    "Pre-built components for Qwik and React frameworks",
    "Gradient backgrounds with customizable angles and mixing",
    "Toggle, dropdown, and navigation components",
    "Built-in markdown formatting styles",
    "Customizable theming with CSS variables",
    "Ready-to-use SVG logos for popular platforms"
  ],
  "publicApiSurface": [
    "@luminescent/ui - Base Tailwind CSS utilities and styles",
    "@luminescent/ui/formatting - Markdown formatting styles",
    "@luminescent/ui-qwik - Qwik component library",
    "@luminescent/ui-react - React component library",
    "lum-bg-* utility - Background color with depth effects",
    "lum-grad-bg-* utility - Gradient background with depth effects",
    "lum-btn utility - Button styling with hover and active states",
    "lum-card utility - Card container with consistent styling",
    "lum-input utility - Input field styling",
    "lum-toggle-bg-* utility - Toggle switch background colors",
    "rounded-lum utility - Border radius with superellipse shape",
    "border-gradient-* utility - Gradient borders",
    "lum-hoverable utility - Hover scale and shadow effects",
    "lum-loading utility - Loading spinner animation",
    "Dropdown component - Expandable dropdown with chevron",
    "Toggle component - Checkbox/switch toggle",
    "Nav component - Navigation bar",
    "SelectMenu component - Dropdown select menu",
    "ColorPicker component - Color selection input",
    "NumberInput component - Numeric input with controls",
    "RangeInput component - Slider input with ticks",
    "Sidebar component - Collapsible sidebar navigation",
    "Anchor component - Styled anchor links",
    "Blobs component - Decorative blob shapes"
  ]
